<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.microsoft.mapper.UserMapper">
    <resultMap id="BaseResultMap" type="com.microsoft.model.entity.User">
        <id property="id" column="id" jdbcType="BIGINT"/>
        <result property="gender" column="gender" jdbcType="TINYINT"/>
        <result property="phone" column="phone" jdbcType="CHAR"/>
        <result property="username" column="username" jdbcType="VARCHAR"/>
        <result property="avatar" column="avatar" jdbcType="VARCHAR"/>
        <result property="password" column="password" jdbcType="VARCHAR"/>
        <result property="role" column="role" jdbcType="TINYINT"/>
        <result property="createTime" column="create_time" jdbcType="TIMESTAMP"/>
        <result property="updateTime" column="update_time" jdbcType="TIMESTAMP"/>
        <result property="userAccount" column="user_account" jdbcType="VARCHAR"/>
        <result property="email" column="email" jdbcType="VARCHAR"/>
        <result property="userStatus" column="user_status" jdbcType="TINYINT"/>
        <result property="isDelete" column="is_delete" jdbcType="TINYINT"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,gender,phone,
        username,avatar,password,
        `role`,create_time,update_time,
        user_account,email,user_status,
        is_delete
    </sql>
</mapper>
